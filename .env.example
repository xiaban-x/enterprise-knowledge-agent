# EdgeOne Pages AI Gateway (required)
AI_GATEWAY_API_KEY=your-ai-gateway-api-key
AI_GATEWAY_BASE_URL=https://your-gateway.edgeone.app/v1

# Model selection (optional, default: @Pages/deepseek-v4-flash)
AI_MODEL=@Pages/deepseek-v4-flash

# EdgeOne Pages Blob storage (auto-injected on deployment, needed for local dev)
PROJECT_ID=pages-your-project-id
EDGEONE_PAGES_API_TOKEN=your-pages-api-token
